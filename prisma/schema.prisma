generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model application_details {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id          String?                  @db.Uuid
  sector                  String?
  entity_type             String?
  aum_range               String?
  turnover_range          String?
  identifier_type         identifier_type?
  identifier_value        String?
  fiu_registration_number String?
  iamai_certificate_url   String?
  iba_certificate_url     String?
  iba_membership_id       String?
  created_at              DateTime?                @default(now()) @db.Timestamp(6)
  membership_applications membership_applications? @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model audit_logs {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type  String?
  entity_id    String?   @db.Uuid
  action       String?
  performed_by String?   @db.Uuid
  metadata     Json?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model flyway_schema_history {
  installed_rank Int      @id(map: "flyway_schema_history_pk")
  version        String?  @db.VarChar(50)
  description    String   @db.VarChar(200)
  type           String   @db.VarChar(20)
  script         String   @db.VarChar(1000)
  checksum       Int?
  installed_by   String   @db.VarChar(100)
  installed_on   DateTime @default(now()) @db.Timestamp(6)
  execution_time Int
  success        Boolean

  @@index([success], map: "flyway_schema_history_s_idx")
}

model membership_applications {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_ref_id  String?               @unique
  application_type    application_type
  organisation_id     String?               @db.Uuid
  user_id             String?               @db.Uuid
  status              application_status    @default(INIT)
  fee_amount          Decimal?              @db.Decimal(12, 2)
  fee_waived          Boolean?              @default(false)
  aum_range           String?
  turnover_range      String?
  is_iamai_member     Boolean?              @default(false)
  is_iba_member       Boolean?              @default(false)
  reviewed_by         String?               @db.Uuid
  reviewed_at         DateTime?             @db.Timestamp(6)
  rejection_reason    String?
  activation_token    String?
  activation_expiry   DateTime?             @db.Timestamp(6)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  updated_at          DateTime?             @default(now()) @db.Timestamp(6)
  application_details application_details[]
  memberships         memberships?
  payments            payments[]
  users               users?                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations       organisations?        @relation(fields: [organisation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_application_status")
}

model memberships {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  membership_id_ref       String?                  @unique
  organisation_id         String?                  @db.Uuid
  application_id          String?                  @unique @db.Uuid
  status                  membership_status        @default(ACTIVE)
  start_date              DateTime                 @db.Date
  end_date                DateTime                 @db.Date
  certificate_url         String?
  created_at              DateTime?                @default(now()) @db.Timestamp(6)
  membership_applications membership_applications? @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations           organisations?           @relation(fields: [organisation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model organisations {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id_ref              String?         @unique
  name                    String
  website                 String?
  sector                  String
  entity_type             String
  registered_address      String
  regulated_entity        Boolean
  identifier_type         identifier_type
  identifier_value        String
  fiu_registration_number String?
  created_at              DateTime?       @default(now()) @db.Timestamp(6)
  updated_at              DateTime?       @default(now()) @db.Timestamp(6)
  memberships             memberships[]
  users                   users[]
  membership_applications membership_applications[]

  @@unique([identifier_type, identifier_value])
  @@index([identifier_type, identifier_value], map: "idx_org_identifier")
}

model payments {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_ref_id          String?                  @unique
  application_id          String?                  @db.Uuid
  amount                  Decimal                  @db.Decimal(12, 2)
  currency                String?                  @default("INR")
  status                  payment_status
  provider                String?
  provider_payment_id     String?                  @unique
  provider_order_id       String?
  paid_at                 DateTime?                @db.Timestamp(6)
  created_at              DateTime?                @default(now()) @db.Timestamp(6)
  membership_applications membership_applications? @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status], map: "idx_payment_status")
}

model users {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organisation_id String?        @db.Uuid
  full_name       String
  designation     String
  email           String         @unique
  mobile          String
  aadhaar         String?
  passport        String?
  username        String         @unique
  password_hash   String
  is_primary      Boolean?       @default(true)
  is_active       Boolean?       @default(false)
  created_at      DateTime?      @default(now()) @db.Timestamp(6)
  organisations           organisations?            @relation(fields: [organisation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  membership_applications membership_applications[]
  password_reset_tokens   password_reset_tokens[]
}

model User {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String       @unique
  name      String
  password  String?      // nullable initially
  status    UserStatus   @default(INITIATED)
  createdAt DateTime     @default(now()) @db.Timestamp(6)
  updatedAt DateTime     @default(now()) @db.Timestamp(6)

  formB       FormB?
  approvals   Approval[]
  resumeToken ResumeToken?
  payment     Payment?
}

model FormB {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String       @unique @db.Uuid
  user             User         @relation(fields: [userId], references: [id])
  organisationName String
  details          Json
  status           FormBStatus  @default(PENDING)
  submittedAt      DateTime     @default(now()) @db.Timestamp(6)
}

model Admin {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email    String    @unique
  password String    // hashed
  role     AdminRole @default(Admin)
}

model Approval {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String         @db.Uuid
  user       User           @relation(fields: [userId], references: [id])
  stage      ApprovalStage
  status     ApprovalStatus @default(PENDING)
  reviewedBy String?        // Admin ID or name
  remarks    String?
  createdAt  DateTime       @default(now()) @db.Timestamp(6)
}

model password_reset_tokens {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String   @db.Uuid
  user      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token     String   @unique
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model ResumeToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime @db.Timestamp(6)
  used      Boolean  @default(false)
}

model Payment {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String        @unique @db.Uuid
  user      User          @relation(fields: [userId], references: [id])
  status    PaymentStatus @default(PENDING)
  amount    Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now()) @db.Timestamp(6)
}

enum UserStatus {
  INITIATED
  FORM_B_SUBMITTED
  UNDER_ADMIN_REVIEW
  APPROVED_STAGE1
  RESUME_PENDING
  IAMAI_PENDING
  PAYMENT_PENDING
  POST_FORM_SUBMITTED
  FINAL_REVIEW
  ACTIVE
}

enum FormBStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStage {
  FORM_B
  FINAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminRole {
  ARIFAC_ADMIN
  Admin
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum application_status {
  INIT
  BASIC_SUBMITTED
  UNDER_REVIEW
  REJECTED
  APPROVED
  FULL_FORM_PENDING
  FULL_FORM_SUBMITTED
  VERIFIED
  FEE_CALCULATED
  PAYMENT_PENDING
  PAYMENT_SUCCESS
  ACTIVATION_PENDING
  ACTIVE
}

enum application_type {
  PRE_APPROVED
  NON_PRE_APPROVED
  FORM_C
}

enum identifier_type {
  CIN
  GST
  PAN
  LLPIN
  TAN
  FIU_REG
  SEBI
  RBI
  IRDAI
  OTHER
}

enum membership_status {
  ACTIVE
  EXPIRED
  SUSPENDED
  PENDING
}

enum payment_status {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
}

model EmailOTP {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  otp       String   // hashed
  expiresAt DateTime @db.Timestamp(6)
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@index([email])
  @@map("EmailOTP")
}

model sequences {
  type     String
  year     Int
  last_val Int    @default(0)

  @@id([type, year])
  @@map("sequences")
}
